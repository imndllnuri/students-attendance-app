}

QPushButton#close_window_btn {
    background-color: transparent;
    border: none;
    border-radius: 14px;
}

QPushButton#close_window_btn:hover {
    background-color: rgba(220, 38, 38, 15);
}

QToolButton {
    background-color: transparent;
    border: none;
    color: {{accent}};
    font-size: 8pt;
}

QToolButton:hover {
    color: {{accent_hover}};
}

QCheckBox {
