# Template only - copy to /etc/tapin/tapin.env on the server machine and
# fill in real values there. Never commit a filled-in copy of this file.
#
#   sudo mkdir -p /etc/tapin
#   sudo cp deploy/tapin.env.example /etc/tapin/tapin.env
#   sudo nano /etc/tapin/tapin.env
#   sudo chmod 600 /etc/tapin/tapin.env
#
# Generate a real random API key with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

TAPIN_DB_PATH=/var/lib/tapin/attendance.db
TAPIN_API_KEY=changeme-generate-a-real-random-token
